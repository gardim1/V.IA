OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=8
OPENAI_MAX_RETRIES=1

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_RAG_MODEL=qwen3:4b
OLLAMA_EMBED_MODEL=mxbai-embed-large

REDIS_URL=redis://localhost:6379
CHAT_TTL_SECONDS=2592000

CONTACT_STORAGE_FILE=data/contact_leads.jsonl
ADMIN_CONTACT_TOKEN=change-this-admin-token

ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

RATE_LIMIT_ENABLED=true
RATE_LIMIT_CHAT_LIMIT=20
RATE_LIMIT_CHAT_WINDOW_SECONDS=60
RATE_LIMIT_CONTACT_LIMIT=5
RATE_LIMIT_CONTACT_WINDOW_SECONDS=3600
RATE_LIMIT_ADMIN_LIMIT=30
RATE_LIMIT_ADMIN_WINDOW_SECONDS=60
